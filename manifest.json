{
  "manifest_version": 3,
  "name": "Banner Blocker",
  "version": "1.0.0",
  "description": "Block specific annoying banners on websites. Minimal permissions, zero data egress.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.atlassian.net/*"],
      "js": ["banners.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src 'none'; script-src 'self'"
  }
}
